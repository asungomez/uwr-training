# The SPA calls the API at the same-origin "/api" path by default (proxied to
# the back-end by Vite in dev and a Render rewrite in prod), so normally no
# config is needed. Uncomment to point the SPA at an absolute API URL instead.
# VITE_API_URL=http://localhost:8000

# Dev-only: where the Vite dev server proxies /api. Compose sets this to
# http://api:8000; on the host it defaults to http://localhost:8000.
# API_PROXY_TARGET=http://localhost:8000
